#!/bin/zsh

XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-"$HOME/.config"}

# ################## #
# SCRIPTING ADDITION #
# ################## #

yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# ####### #
# SIGNALS #
# ####### #

yabai -m signal --add event=space_changed action="${XDG_CONFIG_HOME:-$HOME/.config}/yabai/clean_empty_spaces.sh; sketchybar --trigger spaces_refresh"
yabai -m signal --add event=space_created action="sketchybar --trigger spaces_refresh"
yabai -m signal --add event=space_destroyed action="sketchybar --trigger spaces_refresh"

# Focus the space where the activated app already has a window.
# AXSystemDialog overlays (Tuple Host, Zoom HUD) appear on an arbitrary
# display; when the activation is caused by the overlay itself, bounce focus
# to a real window on the overlay's display instead of following to its space.
yabai -m signal --add event=application_activated action='
  [ -f /tmp/yabai-moving ] && exit 0
  windows=$(yabai -m query --windows)
  active=$(echo "$windows" | jq -c "
    [.[] | select(.pid == $YABAI_PROCESS_ID)] |
    (map(select(.\"has-focus\" == true)) + .) | first
  ")
  [ "$active" = "null" ] && exit 0
  if [ "$(echo "$active" | jq -r .subrole)" = "AXSystemDialog" ] \
     && [ "$(echo "$active" | jq -r ".\"has-focus\"")" = "true" ]; then
    display=$(echo "$active" | jq -r .display)
    target=$(echo "$windows" | jq -re "[.[] | select(.display == $display and .subrole != \"AXSystemDialog\" and .\"is-minimized\" == false and .\"is-hidden\" == false and .\"is-visible\" == true)] | first | .id")
    [ -n "$target" ] && yabai -m window --focus "$target"
  else
    space=$(echo "$active" | jq -r .space)
    [ -n "$space" ] && [ "$space" != "null" ] && yabai -m space --focus "$space"
  fi
'

# Notify SketchyBar which window is focused (enables per-window icon highlighting)
yabai -m signal --add event=window_focused action="sketchybar --trigger window_focused WINDOW_ID=\$YABAI_WINDOW_ID"

# Re-query window order in SketchyBar when windows swap/move positions
yabai -m signal --add event=window_moved action="sketchybar --trigger windows_on_spaces_changed"
yabai -m signal --add event=window_resized action="sketchybar --trigger windows_on_spaces_changed"
yabai -m signal --add event=window_minimized action="sketchybar --trigger windows_on_spaces_changed"
yabai -m signal --add event=window_deminimized action="sketchybar --trigger windows_on_spaces_changed"
yabai -m signal --add event=application_hidden action="sketchybar --trigger windows_on_spaces_changed"
yabai -m signal --add event=application_visible action="sketchybar --trigger windows_on_spaces_changed"

# Restore spaces when displays are added or removed (debounced so rapid
# events like plugging in two monitors settle before labeling)
yabai -m signal --add event=display_added action="${XDG_CONFIG_HOME:-$HOME/.config}/yabai/debounce_restore.sh &"
yabai -m signal --add event=display_removed action="${XDG_CONFIG_HOME:-$HOME/.config}/yabai/debounce_restore.sh &"
yabai -m signal --add event=system_woke action="${XDG_CONFIG_HOME:-$HOME/.config}/yabai/debounce_restore.sh &"

# ##### #
# RULES #
# ##### #

# Exclude problematic apps from being managed:
unmanaged_apps=(
  "1Password"
  "Activity Monitor"
  "App Store"
  "Archive Utility"
  "Bitwarden"
  "Calculator"
  "Dictionary"
  "Logi Options+"
  "Photo Booth"
  "Python"
  "Raycast"
  "Software Update"
  "Steam"
  "System Preferences"
  "System Settings"
  "VLC"
)

join_by() { local IFS="$1"; shift; echo "$*"; }

yabai -m rule --add app="^($(join_by '|' "${unmanaged_apps[@]}"))$" manage=off

yabai -m rule --add label="Finder" app="^Finder$" title="(Co(py|nnect)|Move|Info|Pref)" manage=off
yabai -m rule --add label="Safari" app="^Safari$" title="^(General|(Tab|Password|Website|Extension)s|AutoFill|Se(arch|curity)|Privacy|Advance)$" manage=off
yabai -m rule --add label="About This Mac" app="System Information" title="About This Mac" manage=off
yabai -m rule --add label="Tuple Host" app="^Tuple$" title="^Host$" manage=off

# Space assignments:
chat_apps=("Slack" "zoom.us" "Tuple")
code_apps=("kitty" "Claude" "Cursor" "Codes" "Code")
docs_apps=("Notion" "Slab" "Figma" "Firefox"{{- if .forWork }} "Google Chrome"{{- end }})

yabai -m rule --add label="chat" app="^($(join_by '|' "${chat_apps[@]}"))$" space=chat
yabai -m rule --add label="code" app="^($(join_by '|' "${code_apps[@]}"))$" space=code
yabai -m rule --add label="docs" app="^($(join_by '|' "${docs_apps[@]}"))$" space=docs

# ############### #
# GLOBAL SETTINGS #
# ############### #

yabai -m config \
  debug_output off \
  external_bar all:42:0 \
  menubar_opacity 1.0 \
  mouse_follows_focus off \
  focus_follows_mouse on \
  display_arrangement_order horizontal \
  window_origin_display focused \
  window_placement second_child \
  window_insertion_point focused \
  window_zoom_persist off \
  window_shadow float \
  window_opacity off \
  window_animation_duration 0.3 \
  window_animation_easing ease_out_circ \
  insert_feedback_color 0xff9dd274 \
  split_ratio 0.50 \
  mouse_modifier fn \
  mouse_action1 move \
  mouse_action2 resize \
  mouse_drop_action swap

# ############## #
# SPACE SETTINGS #
# ############## #

# Ensure at least 3 spaces exist, labeled left-to-right across displays:
#   left → chat, center → code, right → docs
${XDG_CONFIG_HOME:-$HOME/.config}/yabai/restore_spaces.py

yabai -m config \
  layout stack \
  split_type auto \
  top_padding 0 \
  bottom_padding 3 \
  left_padding 3 \
  right_padding 3 \
  window_gap 6 \
  auto_balance off

# vim: ft=sh
