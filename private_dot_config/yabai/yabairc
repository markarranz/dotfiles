#!/bin/zsh

XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-"$HOME/.config"}

# ################## #
# SCRIPTING ADDITION #
# ################## #

yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# ####### #
# SIGNALS #
# ####### #

yabai -m signal --add event=space_changed action='/usr/bin/env sh -c "${XDG_CONFIG_HOME:-$HOME/.config}/yabai/clean_empty_spaces.sh"'

# Focus the space where the activated app already has a window
yabai -m signal --add event=application_activated action='
  space=$(yabai -m query --windows | jq -r "first(.[] | select(.pid == $YABAI_PROCESS_ID)).space // empty" 2>/dev/null)
  [ -n "$space" ] && yabai -m space --focus "$space"
'

# Restore spaces when displays are added or removed
yabai -m signal --add event=display_added action='/usr/bin/env sh -c "${XDG_CONFIG_HOME:-$HOME/.config}/yabai/restore_spaces.sh &"'
yabai -m signal --add event=display_removed action='/usr/bin/env sh -c "${XDG_CONFIG_HOME:-$HOME/.config}/yabai/restore_spaces.sh &"'

# ##### #
# RULES #
# ##### #

# Exclude problematic apps from being managed:
unmanaged_apps=(
  "1Password"
  "Activity Monitor"
  "App Store"
  "Archive Utility"
  "Bitwarden"
  "Calculator"
  "Dictionary"
  "Logi Options+"
  "Photo Booth"
  "Python"
  "Raycast"
  "Software Update"
  "Steam"
  "System Preferences"
  "System Settings"
  "VLC"
)

join_by() { local IFS="$1"; shift; echo "$*"; }

yabai -m rule --add app="^($(join_by '|' "${unmanaged_apps[@]}"))$" manage=off

yabai -m rule --add label="Finder" app="^Finder$" title="(Co(py|nnect)|Move|Info|Pref)" manage=off
yabai -m rule --add label="Safari" app="^Safari$" title="^(General|(Tab|Password|Website|Extension)s|AutoFill|Se(arch|curity)|Privacy|Advance)$" manage=off
yabai -m rule --add label="About This Mac" app="System Information" title="About This Mac" manage=off

# Space assignments:
chat_apps=("Slack" "zoom.us" "Tuple")
code_apps=("kitty" "Claude" "Cursor" "Codes" "Code")
docs_apps=("Notion" "Slab" "Figma")

yabai -m rule --add label="chat" app="^($(join_by '|' "${chat_apps[@]}"))$" space=chat
yabai -m rule --add label="code" app="^($(join_by '|' "${code_apps[@]}"))$" space=code
yabai -m rule --add label="docs" app="^($(join_by '|' "${docs_apps[@]}"))$" space=docs

# ############### #
# GLOBAL SETTINGS #
# ############### #

yabai -m config \
  debug_output off \
  external_bar all:42:0 \
  menubar_opacity 1.0 \
  mouse_follows_focus off \
  focus_follows_mouse on \
  display_arrangement_order horizontal \
  window_origin_display focused \
  window_placement second_child \
  window_insertion_point focused \
  window_zoom_persist off \
  window_shadow float \
  window_opacity off \
  window_opacity_duration 0.2 \
  active_window_opacity 1.0 \
  normal_window_opacity 0.95 \
  window_animation_duration 0.3 \
  window_animation_easing ease_out_circ \
  insert_feedback_color 0xff9dd274 \
  split_ratio 0.50 \
  mouse_modifier fn \
  mouse_action1 move \
  mouse_action2 resize \
  mouse_drop_action swap

# ############## #
# SPACE SETTINGS #
# ############## #

# Ensure at least 3 spaces exist, then label them left-to-right across displays:
#   left → chat, center → code, right → docs
labels=(chat code docs)

current_count=$(yabai -m query --spaces | jq length)
for ((n = current_count + 1; n <= $#labels; n++)); do
  yabai -m space --create
done

# Collect all space indices ordered by physical display position (left→right), then index
spaces=($(yabai -m query --displays | jq -r '
  sort_by(.frame.x) | .[].index' |
  while read -r display; do
    yabai -m query --spaces --display "$display" | jq -r 'sort_by(.index) | .[].index'
  done
))

for ((i = 1; i <= $#labels; i++)); do
  [[ -n "${spaces[$i]:-}" ]] && yabai -m space "${spaces[$i]}" --label "${labels[$i]}"
done

yabai -m config \
  layout stack \
  split_type auto \
  top_padding 0 \
  bottom_padding 3 \
  left_padding 3 \
  right_padding 3 \
  window_gap 6 \
  auto_balance off

# vim: ft=sh
