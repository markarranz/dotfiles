#!/usr/bin/env bash
set -euo pipefail

# Listens on Hyprland's event socket and shuffles Discord onto special:magic
# while a Steam/Proton game is open. When the last game window closes, Discord
# goes back to workspace 1. Games are detected by their steam_app_<appid> class.

socket="${XDG_RUNTIME_DIR}/hypr/${HYPRLAND_INSTANCE_SIGNATURE}/.socket2.sock"

move_discord_to() {
	local target="$1"
	hyprctl clients -j |
		jq -r '.[] | select(.class | test("^(discord|vesktop|webcord)$"; "i")) | .address' |
		while read -r addr; do
			# hyprctl dispatch is evaluated as Lua by this hyprland config, so
			# the move goes through the hl dispatcher rather than a keyword.
			[[ -n "$addr" ]] &&
				hyprctl dispatch "hl.dsp.window.move({ workspace = \"$target\", window = \"address:$addr\" })" >/dev/null
		done
}

any_game_open() {
	hyprctl clients -j | jq -e 'any(.[]; .class | test("^steam_app_[0-9]+$"))' >/dev/null
}

game_mode=0
if any_game_open; then
	move_discord_to "special:magic"
	game_mode=1
fi

nc -U "$socket" | while IFS= read -r line; do
	case "$line" in
	openwindow*)
		if any_game_open; then
			move_discord_to "special:magic"
			game_mode=1
		fi
		;;
	closewindow*)
		# brief delay so the closed window is gone from hyprctl state
		sleep 0.2
		if [[ "$game_mode" == 1 ]] && ! any_game_open; then
			move_discord_to "1"
			game_mode=0
		fi
		;;
	esac
done
