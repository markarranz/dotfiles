<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.user.mic-monitor</string>

  <key>ProgramArguments</key>
  <array>
    <string>{{- .chezmoi.homeDir -}}/.config/sketchybar/helpers/mic-monitor/mic-monitor</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>5</integer>

  <key>StandardOutPath</key>
  <string>{{- .chezmoi.homeDir -}}/Library/Logs/com.user.mic-monitor.log</string>

  <key>StandardErrorPath</key>
  <string>{{- .chezmoi.homeDir -}}/Library/Logs/com.user.mic-monitor.log</string>
</dict>
</plist>
