{{- if .forWork }}
local work_dir = vim.fn.expand("~/Code/work/")

return {
  {
    "neovim/nvim-lspconfig",
    opts = {
      servers = {
        gopls = {
          settings = {
            gopls = {
              gofumpt = false,
            },
          },
        },
      },
    },
  },
  {
    "stevearc/conform.nvim",
    optional = true,
    opts = {
      formatters_by_ft = {
        go = { "core_golangci_lint" },
      },
      formatters = {
        core_golangci_lint = {
          command = "core-golangci-lint",
          args = { "fmt", "$DIRNAME" },
          stdin = false,
          condition = function(_, ctx)
            return vim.startswith(ctx.filename, work_dir)
          end,
          cwd = require("conform.util").root_file({
            ".golangci.yml",
            ".golangci.yaml",
            "go.mod",
          }),
          exit_codes = { 0, 1 },
        },
      },
    },
  },
  {
    "folke/snacks.nvim",
    opts = {
      dashboard = {
        preset = {
          header = table.concat({
            "в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—          вң¶",
            "в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ в–Ҳв–Ҳв•‘в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ      вңҰ    ",
            "в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   вң§       ",
            "в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘ В·         ",
            "в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘           ",
            "в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•җв•қ           ",
          }, "\n"),
        },
      },
    },
  },
  {
    "mfussenegger/nvim-lint",
    optional = true,
    opts = function()
      local lint = require("lint")
      local linter = lint.linters.golangcilint
      local default_cmd = linter.cmd
      local default_exit_codes = vim.deepcopy(linter.exit_codes or { 0, 1 })
      local default_args = linter.args and vim.deepcopy(linter.args) or {}

      local work_args = linter.args and vim.deepcopy(linter.args) or {}
      for i, arg in ipairs(work_args) do
        if type(arg) == "function" then
          work_args[i] = function()
            return vim.fn.fnamemodify(vim.api.nvim_buf_get_name(0), ":h")
          end
          break
        end
      end

      vim.api.nvim_create_autocmd("BufEnter", {
        pattern = "*.go",
        callback = function()
          if vim.startswith(vim.api.nvim_buf_get_name(0), work_dir) then
            linter.cmd = "core-golangci-lint"
            linter.exit_codes = { 0, 1, 3 }
            linter.args = work_args
          else
            linter.cmd = default_cmd
            linter.exit_codes = default_exit_codes
            linter.args = default_args
          end
        end,
      })
    end,
  },
  {
    dir = "~/Code/personal/codetour.nvim",
    event = "VeryLazy",
  },
}
{{- end }}
