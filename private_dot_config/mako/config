font=JetBrainsMono Nerd Font 11

background-color=#1e1e2eee
text-color=#cdd6f4ff
border-color=#45475aff
progress-color=over #313244ff

border-size=1
border-radius=12

padding=12
margin=10

default-timeout=5000
width=360
height=110

icons=1
markup=1
actions=1
history=1

format=<b>%s</b>\n%b

[urgency=low]
