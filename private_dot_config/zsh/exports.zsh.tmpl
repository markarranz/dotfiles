#########
# LINUX #
#########
{{- if eq .chezmoi.os "linux" }}

# bun:
if [[ -s "$HOME/.bun/_bun" ]]; then
  source "$HOME/.bun/_bun"
  export BUN_INSTALL="$HOME/.bun"
  export PATH="$BUN_INSTALL/bin:$PATH"
fi

# node-version-manager (lazy-loaded; first call to nvm/node/npm/etc sources nvm.sh)
export NVM_DIR="$HOME/.nvm"
if [[ -f /usr/share/nvm/init-nvm.sh ]]; then
  _nvm_sh="/usr/share/nvm/init-nvm.sh"
  _load_nvm() {
    unfunction nvm node npm npx pnpm yarn corepack _load_nvm 2>/dev/null
    source "$_nvm_sh"
    unset _nvm_sh
  }
  for _cmd in nvm node npm npx pnpm yarn corepack; do
    eval "${_cmd}() { _load_nvm; ${_cmd} \"\$@\"; }"
  done
  unset _cmd
fi

# java (temurin):
[[ -d "$HOME/.local/jdks/jdk-21" ]] && export JAVA_HOME="$HOME/.local/jdks/jdk-21"
[[ -n "$JAVA_HOME" && -d "$JAVA_HOME/bin" ]] && export PATH="$JAVA_HOME/bin:$PATH"

# texlive:
[[ -d "/usr/local/texlive" ]] && export PATH="/usr/local/texlive/2025/bin/x86_64-linux:$PATH"

##########
# DARWIN #
##########
{{- else if and (eq .chezmoi.os "darwin") (not .forWork) }}

# node-version-manager (lazy-loaded; first call to nvm/node/npm/etc sources nvm.sh)
export NVM_DIR="$HOME/.nvm"
if [[ -s "/opt/homebrew/opt/nvm/nvm.sh" ]]; then
  _nvm_sh="/opt/homebrew/opt/nvm/nvm.sh"
  _nvm_comp="/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"
  _load_nvm() {
    unfunction nvm node npm npx pnpm yarn corepack _load_nvm 2>/dev/null
    source "$_nvm_sh"
    [[ -s "$_nvm_comp" ]] && source "$_nvm_comp"
    unset _nvm_sh _nvm_comp
  }
  for _cmd in nvm node npm npx pnpm yarn corepack; do
    eval "${_cmd}() { _load_nvm; ${_cmd} \"\$@\"; }"
  done
  unset _cmd
fi

{{- end }}

{{- if eq .chezmoi.os "darwin" }}

# homebrew settings:
export HOMEBREW_NO_UPGRADE_AUTO_UPDATES_CASKS=1

{{- end }}

#######
# ALL #
#######

# go install:
[[ -e $(which go) ]] && export PATH="$PATH:$(go env GOBIN):$(go env GOPATH)/bin"

# mason.nvim:
[[ -d "$HOME/.local/share/nvim/mason/bin" ]] && export PATH="$HOME/.local/share/nvim/mason/bin:$PATH"

# rustup
[[ -r "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# starship:
[[ -x $(which starship) ]] && export STARSHIP_CONFIG="$XDG_CONFIG_HOME/starship/starship.toml"

# uv & uvx
[[ -x "$HOME/.local/share/../bin/uv" ]] && export PATH="$HOME/.local/share/../bin:$PATH"

# zoxide:
[[ -x $(which zoxide) ]] && eval "$(zoxide init zsh)"
