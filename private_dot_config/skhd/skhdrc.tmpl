# #################### #
# APPLICATION COMMANDS #
# #################### #

# semicolon - keycode 0x29
cmd - 0x29         : open -a kitty --args -1=yes
cmd + shift - 0x29 : kitty @ --to unix:$(ls /tmp/mykitty-* 2>/dev/null | head -1) launch --type=os-window --cwd ~

{{ $browser := "Firefox" -}}
{{- if .forWork }}
{{- $browser = "Google Chrome" }}
{{- end -}}
cmd - b         : open -a "{{ $browser }}"
cmd + shift - b : open -na "{{ $browser }}"

cmd - e : open -na Finder $HOME

hyper - r : yabai --restart-service

# mic mute toggle
hyper - m : ~/.config/skhd/toggle-mic.sh

# ############## #
# SPACE COMMANDS #
# ############## #

# Focus space with CMD + ALT + [\t]; focus prev/next space with CTRL + ALT + [hl]; focus left/right display with CMD + ALT + [hl]:
cmd + alt - tab : yabai -m space --focus recent
ctrl + alt - h   : yabai -m space --focus prev || (yabai -m display --focus prev && yabai -m space --focus last)
ctrl + alt - l   : yabai -m space --focus next || (yabai -m display --focus next && yabai -m space --focus first)
cmd + alt - h   : target=$(~/.config/yabai/display_neighbor.sh prev) && yabai -m display --focus "$target"
cmd + alt - l   : target=$(~/.config/yabai/display_neighbor.sh next) && yabai -m display --focus "$target"

# Move window to left/right display (coordinate-sorted) with CMD + ALT + SHIFT + [hl]:
cmd + alt + shift - h : ~/.config/yabai/move_window.sh 'target=$(~/.config/yabai/display_neighbor.sh prev) && yabai -m window --display "$target" --focus'
cmd + alt + shift - l : ~/.config/yabai/move_window.sh 'target=$(~/.config/yabai/display_neighbor.sh next) && yabai -m window --display "$target" --focus'

# Create new space on current display and move focused window to it:
cmd + alt + shift - n : ~/.config/yabai/move_window.sh 'display=$(yabai -m query --displays --display | jq ".index") && yabai -m space --create && new=$(yabai -m query --spaces --display "$display" | jq "map(.index) | max") && yabai -m window --space "$new" && yabai -m space --focus "$new"'

# Rotate window tree:
cmd + alt - r : yabai -m space --rotate 270 # clockwise
cmd + alt - u : yabai -m space --rotate 90  # counter-clockwise

# Mirror window tree across axes:
cmd + alt - 0x2A : yabai -m space --mirror y-axis # \\
cmd + alt - 0x1B : yabai -m space --mirror x-axis # -

# Focus space with CMD + [0-9]:
# yabai returns non-zero when focusing the already-focused space, so we
# guard the create-fallback to only fire when the target space is missing.
cmd - 1 : yabai -m space --focus 1
cmd - 2 : cur=$(yabai -m query --spaces --space | jq '.index'); [ "$cur" = "2" ] || yabai -m space --focus 2 || (yabai -m space --create; yabai -m space --focus last)
cmd - 3 : cur=$(yabai -m query --spaces --space | jq '.index'); [ "$cur" = "3" ] || yabai -m space --focus 3 || (yabai -m space --create; yabai -m space --focus last)
cmd - 4 : cur=$(yabai -m query --spaces --space | jq '.index'); [ "$cur" = "4" ] || yabai -m space --focus 4 || (yabai -m space --create; yabai -m space --focus last)
cmd - 5 : cur=$(yabai -m query --spaces --space | jq '.index'); [ "$cur" = "5" ] || yabai -m space --focus 5 || (yabai -m space --create; yabai -m space --focus last)
cmd - 6 : cur=$(yabai -m query --spaces --space | jq '.index'); [ "$cur" = "6" ] || yabai -m space --focus 6 || (yabai -m space --create; yabai -m space --focus last)
cmd - 7 : cur=$(yabai -m query --spaces --space | jq '.index'); [ "$cur" = "7" ] || yabai -m space --focus 7 || (yabai -m space --create; yabai -m space --focus last)
cmd - 8 : cur=$(yabai -m query --spaces --space | jq '.index'); [ "$cur" = "8" ] || yabai -m space --focus 8 || (yabai -m space --create; yabai -m space --focus last)
cmd - 9 : cur=$(yabai -m query --spaces --space | jq '.index'); [ "$cur" = "9" ] || yabai -m space --focus 9 || (yabai -m space --create; yabai -m space --focus last)
cmd - 0 : cur=$(yabai -m query --spaces --space | jq '.index'); [ "$cur" = "10" ] || yabai -m space --focus 10 || (yabai -m space --create; yabai -m space --focus last)

# Move window to prev/next space with CTRL + ALT + SHIFT + [hl]:
ctrl + alt + shift - h : ~/.config/yabai/move_window.sh 'idx=$(yabai -m query --spaces --space prev | jq ".index") && yabai -m window --space prev && yabai -m space --focus "$idx"'
ctrl + alt + shift - l : ~/.config/yabai/move_window.sh 'idx=$(yabai -m query --spaces --space next | jq ".index") && yabai -m window --space next && yabai -m space --focus "$idx"'

# ############### #
# WINDOW COMMANDS #
# ############### #

# Toggle fullscreen:
cmd + shift - f : yabai -m window --toggle native-fullscreen

# Toggle float:
cmd + alt - f : yabai -m window --toggle float --grid 4:4:1:1:2:2

# Toggle split (horizontal/vertical):
alt - t : yabai -m window --toggle split

# Toggle sticky:
alt - p : yabai -m window --toggle sticky

# Toggle PiP:
cmd + alt - p : yabai -m window --toggle pip

# Toggle layout (bsp/stack):
alt - s : yabai -m space --layout "$([ "$(yabai -m query --spaces --space | jq -r '.type')" = bsp ] && echo stack || echo bsp)"; sketchybar --trigger yabai_layout_change

# Focus window with CMD + [hjkl]
cmd - h : yabai -m window --focus stack.prev || yabai -m window --focus west
cmd - j : yabai -m window --focus stack.next || yabai -m window --focus south
cmd - k : yabai -m window --focus stack.prev || yabai -m window --focus north
cmd - l : yabai -m window --focus stack.next || yabai -m window --focus east

# Move window with CMD + SHIFT + [hjkl]
cmd + shift - h : yabai -m window --warp west
cmd + shift - j : yabai -m window --warp south
cmd + shift - k : yabai -m window --warp north
cmd + shift - l : yabai -m window --warp east

# Move window to space with CMD + SHIFT + [0-9]:
cmd + shift - 1 : ~/.config/yabai/move_window.sh 'yabai -m window --space 1 && yabai -m space --focus 1'
cmd + shift - 2 : ~/.config/yabai/move_window.sh 'yabai -m window --space 2 && yabai -m space --focus 2  || (yabai -m space --create && yabai -m window --space last && yabai -m space --focus last)'
cmd + shift - 3 : ~/.config/yabai/move_window.sh 'yabai -m window --space 3 && yabai -m space --focus 3  || (yabai -m space --create && yabai -m window --space last && yabai -m space --focus last)'
cmd + shift - 4 : ~/.config/yabai/move_window.sh 'yabai -m window --space 4 && yabai -m space --focus 4  || (yabai -m space --create && yabai -m window --space last && yabai -m space --focus last)'
cmd + shift - 5 : ~/.config/yabai/move_window.sh 'yabai -m window --space 5 && yabai -m space --focus 5  || (yabai -m space --create && yabai -m window --space last && yabai -m space --focus last)'
cmd + shift - 6 : ~/.config/yabai/move_window.sh 'yabai -m window --space 6 && yabai -m space --focus 6  || (yabai -m space --create && yabai -m window --space last && yabai -m space --focus last)'
cmd + shift - 7 : ~/.config/yabai/move_window.sh 'yabai -m window --space 7 && yabai -m space --focus 7  || (yabai -m space --create && yabai -m window --space last && yabai -m space --focus last)'
cmd + shift - 8 : ~/.config/yabai/move_window.sh 'yabai -m window --space 8 && yabai -m space --focus 8  || (yabai -m space --create && yabai -m window --space last && yabai -m space --focus last)'
cmd + shift - 9 : ~/.config/yabai/move_window.sh 'yabai -m window --space 9 && yabai -m space --focus 9  || (yabai -m space --create && yabai -m window --space last && yabai -m space --focus last)'
cmd + shift - 0 : ~/.config/yabai/move_window.sh 'yabai -m window --space 10 && yabai -m space --focus 10 || (yabai -m space --create && yabai -m window --space last && yabai -m space --focus last)'

# ######################## #
