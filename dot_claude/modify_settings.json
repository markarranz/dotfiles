#!/bin/bash
# Chezmoi modify_ script for ~/.claude/settings.json
#
# Manages: statusLine (chezmoi owns these)
# Cleans up: stale hooks left from removed config
# Preserves: enabledPlugins, and anything else Claude Code writes

current=$(cat)

# If the file doesn't exist yet, start with empty object
if [ -z "$current" ]; then
  current='{}'
fi

# Keys that chezmoi owns — these always win
managed='{
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/status-line.sh"
  }
}'

# Deep merge: current * managed (managed keys win, rest preserved)
# Then remove stale Notification hook (script was deleted)
echo "$current" | jq --argjson managed "$managed" '
  . * $managed
  | del(.hooks.Notification)
  | if .hooks == {} then del(.hooks) else . end
'
