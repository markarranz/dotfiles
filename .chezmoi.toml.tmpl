{{- $chassisType := "desktop" }}
{{- if eq .chezmoi.os "darwin" }}
{{-   if contains "MacBook" (output "sysctl" "-n" "hw.model") }}
{{-     $chassisType = "laptop" }}
{{-   else }}
{{-     $chassisType = "desktop" }}
{{-   end }}
{{- else if eq .chezmoi.os "linux" }}
{{-   if lookPath "hostnamectl" }}
{{-     $chassisType = (output "hostnamectl" "--json=short" | mustFromJson).Chassis }}
{{-   end }}
{{- else if eq .chezmoi.os "windows" }}
{{-   $chassisType = (output "powershell.exe" "-NoProfile" "-NonInteractive" "-Command" "if ((Get-CimInstance -Class Win32_Battery | Measure-Object).Count -gt 0) { Write-Output 'laptop' } else { Write-Output 'desktop' }") | trim }}
{{- end -}}

{{- $forWork := promptBoolOnce . "forWork" "Is this a work machine" }}

{{- $githubNotifyRepo := "" }}
{{- $devCompletionsDir := "" }}
{{- if $forWork }}
{{-   $githubNotifyRepo = promptStringOnce . "githubNotifyRepo" "GitHub repo for notifications (owner/repo)" }}
{{-   $devCompletionsDir = promptStringOnce . "devCompletionsDir" "Absolute path to internal tool shell-completions dir (blank to skip)" }}
{{- end }}

[data]
chassisType = {{ $chassisType | quote }}
forWork = {{ $forWork }}
githubNotifyRepo = {{ $githubNotifyRepo | quote }}
devCompletionsDir = {{ $devCompletionsDir | quote }}
